---
import Layout from "../layouts/Layout.astro";

const email = "admin@ar27111994.dev";
const siteUrl = "https://ar27111994.dev";

const products = [
  {
    name: "GSD — Get Shit Done",
    tagline: "Spec-driven, context-engineering AI workflow for shipping features fast.",
    category: "Agent Skill",
    status: "Available",
    href: "https://capafy.com/agents/8942381506",
    github: null,
    description:
      "A production-tested AI agent workflow that turns ambiguous briefs into shipped code via tight spec cycles, context injection, and iterative execution loops. Built for engineers who want to stop explaining and start building.",
    tags: ["AI Workflow", "Spec Engineering", "Developer Tooling"],
  },
  {
    name: "Code Quality Standards",
    tagline: "Production code quality standards for AI coding agents.",
    category: "Agent Skill",
    status: "Available",
    href: "https://capafy.com/agents/6593136731",
    github: null,
    description:
      "Enforces correctness > convenience, clarity > cleverness, and maintainability > short-term productivity. Drop this skill into any AI coding agent to raise the floor on what it ships.",
    tags: ["Code Quality", "AI Agents", "Engineering Standards"],
  },
  {
    name: "Astro Optimization",
    tagline: "Optimize Astro sites for performance, accessibility, and SEO.",
    category: "Agent Skill",
    status: "Available",
    href: "https://capafy.com/agents/6468402250",
    github: null,
    description:
      "Covers Core Web Vitals, image optimization, bundle analysis, schema markup, a11y audits, and Vercel/Netlify deployment hardening — all agent-executable.",
    tags: ["Astro", "Performance", "SEO", "Accessibility"],
  },
  {
    name: "CLI Tool QA",
    tagline: "Systematic QA of CLI tools and command pipelines.",
    category: "Agent Skill",
    status: "Available",
    href: "https://capafy.com/agents/6032871618",
    github: null,
    description:
      "Structured test matrix for CLI tools: flag coverage, error paths, stdin/stdout contracts, pipe chains, exit codes, and cross-platform edge cases. Agent-runnable quality gate before shipping.",
    tags: ["CLI", "QA", "Testing", "Developer Tooling"],
  },
  {
    name: "LLM Context — Modular Docs",
    tagline: "Structure project documentation as modular, selectively-loadable context.",
    category: "Agent Skill",
    status: "Available",
    href: "https://capafy.com/agents/7077126072",
    github: null,
    description:
      "Framework for authoring docs that work as AI context units — scoped, cross-referenced, and composable so agents load exactly what they need without bloat.",
    tags: ["Documentation", "LLM Context", "AI Workflows"],
  },
  {
    name: "Release Readiness Audit",
    tagline: "Verify a versioned software release is genuinely complete.",
    category: "Agent Skill",
    status: "Available",
    href: "https://capafy.com/agents/4405743767",
    github: null,
    description:
      "Pre-release checklist: milestone ticket coverage, changelog quality, version bump consistency, test coverage, and deployment gate verification. Stops premature releases before they happen.",
    tags: ["Release Management", "QA", "Audit"],
  },
  {
    name: "Penpot MCP — AI Agent for Design Systems",
    tagline: "AI agent skill for Penpot design workflows via MCP.",
    category: "Open-source Tool",
    status: "Available",
    href: "https://capafy.com/agents/2800442117",
    github: "https://github.com/ar27111994/penpot-mcp",
    description:
      "Create, audit, and maintain Penpot design systems, prototypes, component tokens, and design-to-code workflows using AI agents via the Model Context Protocol. Requires a running Penpot instance.",
    tags: ["Penpot", "MCP", "Design Systems", "AI Workflows"],
  },
  {
    name: "Webhook Debugger and Logger",
    tagline: "Open-source webhook debugging suite — capture, inspect, replay.",
    category: "Open-source Tool",
    status: "Available",
    href: "https://github.com/ar27111994/webhook-debugger-logger",
    github: "https://github.com/ar27111994/webhook-debugger-logger",
    description:
      "Enterprise-grade webhook testing suite for capturing, inspecting, replaying, forwarding, validating, and mocking webhook traffic in real time — without persistent tunnels or paid SaaS dependencies.",
    tags: ["Webhooks", "API Tooling", "Debugging", "Open-source"],
  },
  {
    name: "agent-harness",
    tagline: "CLI for discovering, staging, and wiring reusable AI-agent assets.",
    category: "Open-source Tool",
    status: "In development",
    href: "https://github.com/ar27111994/agent-harness",
    github: "https://github.com/ar27111994/agent-harness",
    description:
      "TypeScript CLI for managing the lifecycle of AI-agent skills, prompts, and host configurations across VS Code/Copilot, OpenCode, Cursor, Zed, Claude Code, and more.",
    tags: ["AI Agents", "CLI", "Developer Tooling", "TypeScript"],
  },
];

const categoryOrder = ["Agent Skill", "Open-source Tool"];
---

<Layout
  title="Products — Ahmed Rehan"
  description="AI agent skills, open-source tools, and developer utilities built by Ahmed Rehan. Webhook debugger, Penpot MCP, agent-harness, and more."
  image="/brand/og-cover.png"
>
  <main class="products-page" id="main-content">
    <div class="container">
      <header class="page-header">
        <a href="/" class="back-link">← ar27111994.dev</a>
        <h1>Products</h1>
        <p class="subtitle">
          AI agent skills, open-source tools, and developer utilities. Built to
          solve real problems in devtools, webhooks, automation, and AI-agent
          workflows.
        </p>
      </header>

      {
        categoryOrder.map((cat) => {
          const items = products.filter((p) => p.category === cat);
          if (!items.length) return null;
          return (
            <section class="category-section">
              <h2 class="category-label">{cat}s</h2>
              <div class="product-grid">
                {items.map((p) => (
                  <article class="product-card">
                    <div class="card-header">
                      <div class="card-meta">
                        <span class={`status-badge ${p.status === "In development" ? "status-dev" : "status-available"}`}>
                          {p.status}
                        </span>
                        <span class="category-chip">{p.category}</span>
                      </div>
                      <h3 class="product-name">{p.name}</h3>
                      <p class="product-tagline">{p.tagline}</p>
                    </div>
                    <p class="product-description">{p.description}</p>
                    <div class="tag-row">
                      {p.tags.map((t) => (
                        <span class="tag">{t}</span>
                      ))}
                    </div>
                    <div class="card-actions">
                      <a href={p.href} class="btn btn-primary" target="_blank" rel="noreferrer">
                        {p.category === "Agent Skill" ? "Get on Capafy" : "View on GitHub"}
                      </a>
                      {p.github && p.category !== "Open-source Tool" && (
                        <a href={p.github} class="btn btn-secondary" target="_blank" rel="noreferrer">
                          GitHub
                        </a>
                      )}
                    </div>
                  </article>
                ))}
              </div>
            </section>
          );
        })
      }

      <section class="cta-section">
        <p>
          Custom tooling, integrations, or automation work?
          <a href={`mailto:${email}`}>Get in touch</a> or see the full
          <a href="/">portfolio</a>.
        </p>
      </section>
    </div>
  </main>
</Layout>

<style>
  .products-page {
    min-height: 100vh;
    padding: 4rem 1.5rem 6rem;
    background: var(--color-bg, #0a0a0a);
    color: var(--color-text, #e5e5e5);
  }

  .container {
    max-width: 1080px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 3.5rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-accent, #7c6af7);
    text-decoration: none;
    font-size: 0.9rem;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .back-link:hover {
    opacity: 1;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
    color: var(--color-heading, #fff);
  }

  .subtitle {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-muted, #aaa);
    max-width: 600px;
    margin: 0;
  }

  .category-section {
    margin-bottom: 3.5rem;
  }

  .category-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted, #888);
    margin: 0 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .product-card {
    background: var(--color-surface, #141414);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s;
  }
  .product-card:hover {
    border-color: rgba(255, 255, 255, 0.18);
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .status-available {
    background: rgba(52, 211, 153, 0.12);
    color: #34d399;
  }
  .status-dev {
    background: rgba(251, 191, 36, 0.12);
    color: #fbbf24;
  }

  .category-chip {
    font-size: 0.7rem;
    color: var(--color-muted, #888);
    font-weight: 500;
  }

  .product-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-heading, #fff);
    margin: 0;
  }

  .product-tagline {
    font-size: 0.875rem;
    color: var(--color-accent, #7c6af7);
    margin: 0;
    font-weight: 500;
  }

  .product-description {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text, #ccc);
    margin: 0;
    flex: 1;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: rgba(124, 106, 247, 0.1);
    color: var(--color-accent, #7c6af7);
    border-radius: 4px;
    font-weight: 500;
  }

  .card-actions {
    display: flex;
    gap: 0.625rem;
    margin-top: auto;
  }

  .btn {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.45rem 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn:hover {
    opacity: 0.85;
  }
  .btn-primary {
    background: var(--color-accent, #7c6af7);
    color: #fff;
  }
  .btn-secondary {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text, #ccc);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .cta-section {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.9rem;
    color: var(--color-muted, #888);
  }
  .cta-section a {
    color: var(--color-accent, #7c6af7);
    text-decoration: none;
  }
  .cta-section a:hover {
    text-decoration: underline;
  }
</style>
