---
import Layout from "../layouts/Layout.astro";
import upworkPortfolio from "../data/upwork-portfolio.json";
import { buildUpworkPortfolioDisplay } from "../data/upwork-portfolio-display";
import { getHomepageContent } from "../data/homepage";
import SiteHeader from "../components/home/SiteHeader.astro";
import HeroSection from "../components/home/HeroSection.astro";
import ServicesSection from "../components/home/ServicesSection.astro";
import CaseStudiesSection from "../components/home/CaseStudiesSection.astro";
import ProjectsSection from "../components/home/ProjectsSection.astro";
import FeedSection from "../components/home/FeedSection.astro";
import UpworkSection from "../components/home/UpworkSection.astro";
import TestimonialsSection from "../components/home/TestimonialsSection.astro";
import ProofSection from "../components/home/ProofSection.astro";
import CapabilitiesSection from "../components/home/CapabilitiesSection.astro";
import PublicSurfacesSection from "../components/home/PublicSurfacesSection.astro";
import SiteFooter from "../components/home/SiteFooter.astro";

const contactEmail = "admin@ar27111994.dev";
const secondaryEmail = "ahmed.rehan@ar27111994.dev";
const whatsappUrl = "https://wa.me/923315887235";
const upworkProfileUrl = upworkPortfolio.profileUrl;

const CAREER_START_YEAR = 2014;
const CAREER_START_MONTH = 7;
const now = new Date();
const yearsOfExperience =
  now.getFullYear() -
  CAREER_START_YEAR -
  (now.getMonth() + 1 < CAREER_START_MONTH ? 1 : 0);
const yearsLabel = `${yearsOfExperience}+`;

const ghPublicRepos = import.meta.env.GITHUB_PUBLIC_REPOS ?? "53";
const ghTotalStars = import.meta.env.GITHUB_TOTAL_STARS ?? "36";

const {
  items: upworkPortfolioItems,
  count: upworkPortfolioCount,
  countLabel: upworkPortfolioCountLabel,
  recentProofTitles: recentUpworkProofTitles,
} = buildUpworkPortfolioDisplay(upworkPortfolio);

const homepageContent = getHomepageContent({
  contactEmail,
  secondaryEmail,
  whatsappUrl,
  upworkProfileUrl,
  yearsLabel,
  ghPublicRepos,
  ghTotalStars,
  upworkPortfolioCount,
  recentUpworkProofTitles,
});

const {
  profileLinks,
  badges,
  proofStackMetrics,
  caseStudies,
  featuredProjects,
  additionalProjects,
  writingLinks,
  feedSources,
  labNotes,
  engagementSteps,
  contactWidgets,
  resumeWidgets,
  profileWidgets,
  upworkProofCards,
  upworkFitTags,
  testimonialCards,
  capabilities,
  credibilityFacts,
  ventureProof,
  certificationLinks,
  openSourceFreemium,
  sponsorLinks,
} = homepageContent;
---

<Layout
  title="Ahmed Rehan — Devtools, Automation, Webhooks, Agent Systems"
  description="Portfolio of Ahmed Rehan: full-stack engineer building developer tools, automation systems, webhook workflows, AI-agent tooling, and reliable performance-conscious software."
  image="/brand/og-cover.png"
>
  <SiteHeader />

  <main class="site-wrap" id="main-content">
    <HeroSection
      contactEmail={contactEmail}
      whatsappUrl={whatsappUrl}
      badges={badges}
      proofStackMetrics={proofStackMetrics}
      credibilityFacts={credibilityFacts}
    />
    <ServicesSection labNotes={labNotes} engagementSteps={engagementSteps} />
    <CaseStudiesSection caseStudies={caseStudies} />
    <ProjectsSection
      featuredProjects={featuredProjects}
      additionalProjects={additionalProjects}
    />
    <FeedSection writingLinks={writingLinks} feedSources={feedSources} />
    <UpworkSection
      upworkProfileUrl={upworkProfileUrl}
      upworkPortfolioCountLabel={upworkPortfolioCountLabel}
      upworkFitTags={upworkFitTags}
      upworkProofCards={upworkProofCards}
      upworkPortfolioItems={upworkPortfolioItems}
    />
    <TestimonialsSection testimonialCards={testimonialCards} />
    <ProofSection
      certificationLinks={certificationLinks}
      ventureProof={ventureProof}
      openSourceFreemium={openSourceFreemium}
    />
    <CapabilitiesSection capabilities={capabilities} />
    <PublicSurfacesSection
      profileWidgets={profileWidgets}
      profileLinks={profileLinks}
      resumeWidgets={resumeWidgets}
      contactWidgets={contactWidgets}
      sponsorLinks={sponsorLinks}
    />
  </main>

  <SiteFooter contactEmail={contactEmail} />
  <script src="../scripts/homepage.ts"></script>
</Layout>
