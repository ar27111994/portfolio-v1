            sizes="112px"
            formats={["avif", "webp"]}
            loading="eager"
            fetchpriority="high"
          />
          <div class="brand-meta">
            <p class="brand-title">ARLabs</p>
            <p class="brand-subtitle">Devtools · Automation · Agent Systems</p>
          </div>
        </div>
        <p class="eyebrow">ar27111994.dev · Rawalpindi, Pakistan</p>
        <h1>
          Developer tools, automation, and agent systems that stay useful after
          the first launch.
        </h1>
        <p class="lede">
          I’m Ahmed Rehan — a <strong>full-stack engineer</strong> who helps teams
          ship <strong
            >devtools, webhook/API workflows, automation, and AI-agent systems</strong
          >
          without leaving reliability, UX, or handoff quality to chance.
        </p>

        <div class="badge-row" aria-label="Profile badges">
          {
            badges.map((badge) => (
              <span>
                {badge.icon ? (
                  <img
                    src={badge.icon}
                    alt=""
                    width="24"
                    height="24"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <b aria-hidden="true">{badge.mark}</b>
                )}
                {badge.label}
              </span>
            ))
          }
        </div>

        <div
          class="hero-actions contact-command-grid"
          aria-label="Primary contact actions"
        >
          <a
            class="button primary icon-button contact-command"
            href={`mailto:${contactEmail}`}
          >
            <span class="command-icon"
              ><img
                src="/brand-icons/gmail.svg"
                alt=""
                width="24"
                height="24"
                loading="lazy"
                decoding="async"
              /></span
            >
            <span class="command-copy"
              ><small>Primary contact</small><strong
                >Email the project brief</strong
              ></span
            >
          </a>
          <a
            class="button whatsapp icon-button contact-command"
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
          >
            <span class="command-icon"
              ><img
                src="/brand-icons/whatsapp.svg"
                alt=""
                width="24"
                height="24"
                loading="lazy"
                decoding="async"
              /></span
            >
            <span class="command-copy"
              ><small>Fast follow-up</small><strong>WhatsApp</strong></span
            >
          </a>
        </div>
        <p class="hero-secondary-link">
          Need background first? <a
            href="/resume/resume_full.pdf"
            target="_blank"
            rel="noreferrer">Open the full resume</a
          >.
        </p>

        <div
          class="availability-strip availability-command-strip"
          aria-label="Best-fit work and working style"
        >
          <span class="availability-card"
            ><b>BEST FIT</b><strong
              >Devtools, webhook/API debugging, automation, and AI-agent systems</strong
            ><small
              >Work where messy flows need a practical engineer who can clarify
              the system and still ship it cleanly.</small
            ></span
          >
          <span class="availability-card"
            ><b>WORKING STYLE</b><strong
              >Remote-friendly · async-ready · scoped before code</strong
            ><small
              >Written plans, visible tradeoffs, verified slices, and handoff
              material instead of vague status updates.</small
            ></span
          >
        </div>
      </div>

      <aside class="hero-aside" aria-label="Quick profile facts">
        <div class="signal-board">
          <span class="signal-kicker">Public work snapshot</span>
          <strong>Devtools · webhooks · automation · agent systems</strong>
          <div class="signal-metrics" aria-label="Public work metrics">
            {
              proofStackMetrics.map((metric) => (
                <span title={metric.detail}>
                  <b
                    data-proof-value={metric.stat}
                    aria-live={metric.stat ? "polite" : undefined}
                  >
                    {metric.value}
                  </b>
                  <small>{metric.label}</small>
                </span>
              ))
            }
          </div>
          <div class="signal-tags">
            <span>Devtools</span><span>Webhooks</span><span>Automation</span
            ><span>OSS</span><span>Docs</span>
          </div>
          <p class="signal-note" data-proof-status>
            Build-time GitHub snapshot refreshed during deploys.
          </p>
        </div>
        <div class="snapshot-block">
          <h2>Why teams bring me in</h2>
          <ul class="bullet-clean snapshot-list">
            {
              credibilityFacts.map((item) => (
                <li>
                  <span class="snapshot-icon" aria-hidden="true">
                    {item.icon}
                  </span>
                  <span>{item.text}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </aside>
    </section>

    <section class="panel lab-panel" aria-labelledby="lab-title">
      <div class="section-head split-head">
        <div>
          <p class="section-kicker">Services</p>
          <h2 id="lab-title">What I build</h2>
          <p>
            Focused engineering help for teams that need practical software,
            cleaner operations, or a calmer path through messy integration and
            tooling work.
          </p>
        </div>
      </div>
      <div class="grid two service-grid">
        {
          labNotes.map((item) => (
            <article class="lab-card service-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
      <div class="section-head split-head section-subhead">
        <div>
          <p class="section-kicker">How we start</p>
          <p>
            Short version: send the brief, I turn it into a scoped plan, then we
            ship in small verified slices.
          </p>
        </div>
      </div>
      <div class="support-grid engagement-grid">
        {
          engagementSteps.map((step) => (
            <article class="support-card engagement-card">
              <span class="step-chip">{step.step}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="panel" aria-labelledby="projects-title">
      <div class="section-head">
        <h2 id="projects-title">Featured products</h2>
        <p>
          Live product evidence from the places where the work is actually
          happening: repos, launch surfaces, docs, and systems that can keep
          growing into paid tools.
        </p>
      </div>

      <div class="grid two">
        {
          featuredProjects.map((project) => (
            <article class="project-card">
              <div
                class={`project-visual ${project.accent}`}
                aria-hidden="true"
              >
                <span>{project.visual}</span>
              </div>
              <div class="project-copy">
                <p class="status-tag">{project.status}</p>
                <h3>
                  <a href={project.href} target="_blank" rel="noreferrer">
                    {project.name}
                  </a>
                </h3>
                <p>{project.summary}</p>
                <ul class="mini-list">
                  {project.highlights.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="panel" aria-labelledby="additional-projects-title">
      <div class="section-head">
        <h2 id="additional-projects-title">Product and tooling threads</h2>
        <p>
          Supporting work that shows range beyond the headline tools: visual
          systems, challenge builds, mobile context products, and data-quality
          workflows.
        </p>
      </div>
      <div class="grid four compact">
        {
          additionalProjects.map((project) => (
            <article class="project-card experiment">
              <h3>
                <a href={project.href} target="_blank" rel="noreferrer">
                  {project.name}
                </a>
              </h3>
              <p>{project.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="panel" aria-labelledby="feed-title">
      <div class="section-head split-head">
        <div>
          <h2 id="feed-title">Public work feed</h2>
          <p>
            Recent launch notes and technical writing pulled from public feeds
            when available. The curated fallback stays useful even when
            third-party sources are slow or blocked.
          </p>
        </div>
        <a
          class="button secondary small"
          href="https://dev.to/ar27111994"
          target="_blank"
          rel="noreferrer">Open Dev.to</a
        >
      </div>

      <div class="feed-widget" data-feed-widget>
        <div class="feed-status" data-feed-status>
          Loading public feed items…
        </div>
        <div class="feed-list" data-feed-list></div>
      </div>

      <div
        class="support-grid writing-grid fallback-feed"
        aria-label="Curated fallback feed"
      >
        {
          writingLinks.map((item) => (
            <a
              class="support-card"
              href={item.href}
              target="_blank"
              rel="noreferrer"
            >
              <span class="chip">
                {item.icon && (
                  <img
                    src={item.icon}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    style="width:14px;height:14px;vertical-align:middle;margin-right:4px;"
                  />
                )}
                {item.tag}
              </span>
              <span class="support-name">{item.label}</span>
              <span class="support-note">
                <strong>{item.source}:</strong> {item.date}
              </span>
            </a>
          ))
        }
      </div>

      <details class="feed-sources">
        <summary>Curated feed sources</summary>
        <ul class="feed-source-grid" aria-label="Curated feed source links">
          {
            feedSources.map((source) => (
              <li>
                <a
                  class="feed-source-card"
                  href={source.href}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={`Open ${source.label} ${source.type} feed source`}
                >
                  <span class="feed-source-icon">
                    <img
                      src={source.icon}
                      alt=""
                      width="24"
                      height="24"
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                  <span class="feed-source-copy">
                    <strong>{source.label}</strong>
                    <small>{source.type}</small>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </details>
    </section>

    <section
      id="upwork"
      class="panel upwork-panel"
      aria-labelledby="upwork-title"
    >
      <div class="section-head split-head">
        <div>
          <p class="section-kicker">Freelance track record</p>
          <h2 id="upwork-title">
            Upwork portfolio
            <span class="count-badge" id="upwork-count-badge"
              >{upworkPortfolioCountLabel} projects</span
            >
          </h2>
          <p>
            A client-facing view of Upwork work history: recent developer-tool
            projects first, with older frontend, CMS, e-commerce, dashboard, and
            integration work kept as supporting evidence.
          </p>
        </div>
        <a
          class="button secondary small"
          href={upworkProfileUrl}
          target="_blank"
          rel="noreferrer">View full profile</a
        >
      </div>

      <div class="upwork-intro-grid">
        <article class="upwork-summary-card">
          <span class="signal-kicker">Client-facing profile</span>
          <h3>
            Full-stack engineer for devtools, webhooks, automation, and AI-agent
            work.
          </h3>
          <p>
            The Upwork surface is being tightened around practical engineering
            outcomes: webhook/API debugging, internal tools, automation-heavy
            products, developer tooling, and reliable async delivery.
          </p>
          <div class="upwork-tags" aria-label="Upwork fit tags">
            {upworkFitTags.map((tag) => <span>{tag}</span>)}
          </div>
        </article>

        <div
          class="upwork-proof-grid"
          aria-label="Upwork proof profile details"
        >
          {
            upworkProofCards.map((card) => (
              <article class="upwork-proof-card">
                <small>{card.label}</small>
                <strong>{card.value}</strong>
                <p>{card.detail}</p>
              </article>
            ))
          }
        </div>
      </div>

      <div
        class="upwork-portfolio-grid"
        aria-label="Curated Upwork portfolio projects"
      >
        {
          upworkPortfolioItems.map((item) => (
            <UpworkPortfolioCard item={item} />
          ))
        }
      </div>

      <p class="subtle">
        Full profile remains the source of truth for contracts, reviews, and
        Upwork-native project pages; this section packages the work trail for
        faster scanning.
      </p>
    </section>

    <section class="panel" aria-labelledby="testimonials-title">
      <div class="section-head split-head">
        <div>
          <p class="section-kicker">Recommendations / client quotes</p>
          <h2 id="testimonials-title">
            What people say when the work is done well
          </h2>
          <p>
            Verbatim recommendations from LinkedIn and client review text from
            Upwork. Source links stay attached so the proof is inspectable
            instead of decorative.
          </p>
        </div>
      </div>
      <div class="grid two testimonial-grid">
        {
          testimonialCards.map((item) => (
            <article
              class={`resource-card testimonial-card testimonial-card-${item.sourceKind}${item.featured ? " is-featured" : ""}`}
            >
              <span class="testimonial-source-chip">{item.source}</span>
              <blockquote>{item.quote}</blockquote>
              <div class="testimonial-attribution">
                <strong>{item.author}</strong>
                <small>{item.role}</small>
              </div>
              <div class="testimonial-proof-row">
                <span class="testimonial-context">{item.context}</span>
                <a href={item.href} target="_blank" rel="noreferrer">
                  {item.cta}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="panel" aria-labelledby="proof-title">
      <div class="section-head">
        <h2 id="proof-title">Public credentials, founder history, and OSS</h2>
        <p>
          Verifiable context that supports the current work: public training,
          founder/operator history, and older shipped software that still shows
          how I build.
        </p>
      </div>

      <div class="proof-grid">
        <article class="resource-card">
          <h3>Certifications / public training</h3>
          <ul class="cert-list">
            <li class="cert-item cert-partner">
              <span class="cert-icon-wrap">
                <img
                  src="/brand-icons/anthropic.svg"
                  alt="Anthropic"
                  width="20"
                  height="20"
                  loading="lazy"
                  decoding="async"
                  class="cert-icon"
                />
              </span>
              <div class="cert-body">
                <strong class="cert-name">Anthropic course track</strong>
                <span class="cert-meta"
                  >Public Skilljar verifications are linked below.</span
                >
              </div>
            </li>
            {
              certificationLinks
                .filter((item) => item.issuer === "Anthropic")
                .map((item) => (
                  <li class="cert-item">
                    <span class="cert-icon-wrap">
                      <img
                        src={item.icon}
                        alt={item.issuer}
                        width="20"
                        height="20"
                        loading="lazy"
                        decoding="async"
                        class="cert-icon"
                      />
                    </span>
                    <div class="cert-body">
                      <a
                        href={item.href}
                        target="_blank"
                        rel="noreferrer"
                        class="cert-link"
                      >
                        {item.label}
                      </a>
                      {item.pdf && (
                        <a
                          href={item.pdf}
