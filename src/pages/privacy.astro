---
import Layout from "../layouts/Layout.astro";

const lastUpdated = "June 17, 2026";
const email = "admin@ar27111994.dev";
const siteUrl = "https://ar27111994.dev";
---

<Layout
  title="Privacy Policy — Ahmed Rehan"
  description="Privacy policy for AI agents, tools, and skills published by Ahmed Rehan."
>
  <!-- Minimal top-bar matching the portfolio nav -->
  <header class="top-bar" role="banner">
    <div class="wordmark" aria-label="Ahmed Rehan — ARLabs">
      <span class="wm-mono" aria-hidden="true">AR</span>
      <div class="wm-text">
        <span class="wm-name">Ahmed Rehan</span>
        <span class="wm-studio">ARLabs</span>
      </div>
    </div>
    <a href="/" class="back-nav" aria-label="Back to portfolio">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      Portfolio
    </a>
  </header>

  <main class="privacy-wrap" id="main-content">
    <div class="privacy-container">
      <header class="priv-header">
        <p class="priv-eyebrow">Legal</p>
        <h1>Privacy Policy</h1>
        <p class="priv-meta">
          Last updated: <time datetime="2026-06-17">{lastUpdated}</time>
        </p>
      </header>

      <div class="priv-intro">
        <p>
          This Privacy Policy describes how Ahmed Rehan (<strong>me</strong>)
          collects, uses, and handles information in connection with AI agents,
          skills, tools, and software products published on third-party
          marketplaces (including but not limited to Capafy) and available at <a
            href={siteUrl}>{siteUrl}</a
          >.
        </p>
      </div>

      <div class="priv-body">
        <section class="priv-section">
          <h2><span class="priv-num">01</span> Information I Collect</h2>
          <p>
            My downloadable AI agents and skill packages (<strong
              >Download mode products</strong
            >) run entirely on your local machine or within your own AI agent
            environment. They do not transmit data to my servers. No personal
            information, usage data, or conversation history is collected by me
            when you use these products.
          </p>
          <p>
            When you contact me directly (e.g. via support email), I receive
            only the information you choose to send.
          </p>
        </section>

        <section class="priv-section">
          <h2><span class="priv-num">02</span> How I Use Information</h2>
          <p>
            Any information you voluntarily provide through direct contact
            (email, GitHub issues, marketplace messaging) is used solely to:
          </p>
          <ul>
            <li>Respond to your support requests or questions</li>
            <li>Improve product quality and documentation</li>
          </ul>
          <p>
            I do not sell, rent, or share your personal information with third
            parties.
          </p>
        </section>

        <section class="priv-section">
          <h2><span class="priv-num">03</span> Third-Party Platforms</h2>
          <p>
            My products are distributed through third-party marketplaces (e.g.
            Capafy). When you purchase or download a product through these
            platforms, their own privacy policies apply to any data they collect
            during the transaction. I am not responsible for the privacy
            practices of third-party platforms.
          </p>
        </section>

        <section class="priv-section">
          <h2><span class="priv-num">04</span> Cookies and Analytics</h2>
          <p>
            This portfolio website (<a href={siteUrl}>{siteUrl}</a>) uses Vercel
            Analytics for anonymous, aggregated traffic reporting. No personally
            identifiable data is collected. No tracking cookies are set on your
            device when you visit this site.
          </p>
        </section>

        <section class="priv-section">
          <h2><span class="priv-num">05</span> Data Retention</h2>
          <p>
            I retain support correspondence only as long as necessary to resolve
            your request. You may request deletion of any personal information
            you have provided by emailing me.
          </p>
        </section>

        <section class="priv-section">
          <h2><span class="priv-num">06</span> Children's Privacy</h2>
          <p>
            My products and services are not directed at children under the age
            of 13. I do not knowingly collect personal information from
            children.
          </p>
        </section>

        <section class="priv-section">
          <h2><span class="priv-num">07</span> Changes to This Policy</h2>
          <p>
            I may update this Privacy Policy from time to time. The "Last
            updated" date at the top of this page reflects the most recent
            revision. Continued use of my products after changes are posted
            constitutes your acceptance of the updated policy.
          </p>
        </section>

        <section class="priv-section priv-contact">
          <h2><span class="priv-num">08</span> Contact</h2>
          <p>Questions about this Privacy Policy? Reach me at:</p>
          <a href={`mailto:${email}`} class="contact-link">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            {email}
          </a>
        </section>
      </div>
    </div>
  </main>

  <footer class="priv-footer">
    <p>© {new Date().getFullYear()} Ahmed Rehan · ARLabs</p>
    <a href="/">ar27111994.dev</a>
  </footer>
</Layout>

<style>
  /* ── Layout shell — fills viewport so Layout body never bleeds through ── */
  :global(body) {
    min-height: 100vh;
  }

  /* Top bar — reuse the portfolio nav tokens */
  .top-bar {
    position: sticky;
    top: 0;
    z-index: 80;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem clamp(1.25rem, 4vw, 3rem);
    background: rgba(244, 239, 231, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }

  .back-nav {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink-soft);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .back-nav:hover {
    color: var(--blue);
  }

  /* ── Main content ─────────────────────────────────────────────────── */
  .privacy-wrap {
    min-height: calc(100vh - 60px);
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem) 4rem;
  }

  .privacy-container {
    max-width: 680px;
    margin: 0 auto;
  }

  /* ── Header ───────────────────────────────────────────────────────── */
  .priv-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line);
  }

  .priv-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue);
    margin: 0 0 0.75rem;
  }

  .priv-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--ink);
    margin: 0 0 0.5rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .priv-meta {
    font-size: 0.825rem;
    color: var(--muted);
    margin: 0;
  }

  /* ── Intro block ──────────────────────────────────────────────────── */
  .priv-intro {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }

  .priv-intro p {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--ink-soft);
  }

  /* ── Sections ─────────────────────────────────────────────────────── */
  .priv-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .priv-section {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--line);
  }

  .priv-section:last-child {
    border-bottom: none;
  }

  .priv-section h2 {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 0.875rem;
    letter-spacing: -0.01em;
  }

  .priv-num {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--blue);
    background: color-mix(in srgb, var(--blue) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--blue) 20%, transparent);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    flex-shrink: 0;
    font-family: var(--font-sans);
  }

  .priv-section p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--ink-soft);
    margin: 0 0 0.75rem;
  }

  .priv-section p:last-child {
    margin-bottom: 0;
  }

  .priv-section ul {
    padding-left: 1.25rem;
    margin: 0.5rem 0 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .priv-section li {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  /* ── Contact section ──────────────────────────────────────────────── */
  .priv-contact {
    padding-bottom: 0;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding: 0.65rem 1.1rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    transition:
      border-color 0.15s,
      color 0.15s,
      background 0.15s;
  }

  .contact-link:hover {
    border-color: var(--blue);
    color: var(--blue);
    background: color-mix(in srgb, var(--blue) 5%, var(--card));
  }

  /* ── Links ────────────────────────────────────────────────────────── */
  .priv-section a {
    color: var(--blue);
    text-decoration: none;
    font-weight: 500;
  }

  .priv-section a:hover {
    text-decoration: underline;
  }

  /* ── Footer ───────────────────────────────────────────────────────── */
  .priv-footer {
    border-top: 1px solid var(--line);
    padding: 1.5rem clamp(1.25rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .priv-footer p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .priv-footer a {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }

  .priv-footer a:hover {
    color: var(--blue);
  }
</style>
