{
  "name": "portfolio-v1",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/fetch-portfolio-build.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "astro check",
    "check": "astro check && eslint . && prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{astro,ts,js,mjs,cjs,json,css,md}": [
      "prettier --write"
    ],
    "*.{astro,ts,js,mjs}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.1.10"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@vercel/node": "^5.8.14",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0"
  }
}
