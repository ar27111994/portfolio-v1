{
  "$schema": "../../schema/recommendation-host-policy-override.schema.json",
  "schemaVersion": 1,
  "host": "pi",
  "presetRefs": {
    "targetConcerns": ["delivery-core"]
  },
  "policy": {
    "recommendationLimit": 70,
    "activationBudget": 90,
    "suggestedBundleId": "opencode-global",
    "maxPerSourceFamily": 8,
    "maxPerDuplicateGroup": 6,
    "maxPerAssetKind": {
      "skill": 28,
      "instruction": 16,
      "plugin": 6,
      "agent": 8,
      "workflow": 10,
      "hook": 6,
      "mcp-server": 4,
      "extension": 2,
      "prompt-pack": 12,
      "reference-pack": 8
    },
    "targetAssetKinds": [
      {
        "assetKind": "skill",
        "minimum": 12,
        "weight": 3
      },
      {
        "assetKind": "agent",
        "minimum": 8,
        "weight": 3
      },
      {
        "assetKind": "workflow",
        "minimum": 6,
        "weight": 3
      },
      {
        "assetKind": "instruction",
        "minimum": 6,
        "weight": 2
      },
      {
        "assetKind": "plugin",
        "minimum": 4,
        "weight": 2
      }
    ],
    "deprioritizedPenalty": 64,
    "deprioritizedAssetIdPatterns": [
      "mcp-server",
      "vscode-extension",
      "copilot-extension"
    ],
    "deprioritizedCapabilityTerms": ["mcp", "extension"]
  }
}
